# =============================================================================
#  Composer — vendor/ es regenerable con `composer install`
# =============================================================================
backend/api/vendor/

# =============================================================================
#  Secretos — config.php contiene credenciales reales (DB + JWT secret).
#  Plantilla: backend/api/config.example.php (sí va al repo).
#  Setup local: cp backend/api/config.example.php backend/api/config.php
# =============================================================================
backend/api/config.php

# =============================================================================
#  Datos de runtime (PDFs generados, logs, caches de PHPUnit)
# =============================================================================
backend/storage/
*.log
*.cache
.phpunit.result.cache
.phpunit.cache/

# =============================================================================
#  IDEs y editores
# =============================================================================
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# =============================================================================
#  Sistemas operativos
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
#  Artefactos de build / paquetes
# =============================================================================
*.zip
*.tar.gz

# =============================================================================
#  Python (en caso de scripts auxiliares)
# =============================================================================
__pycache__/
*.pyc

# =============================================================================
#  Android — local config + build outputs (regenerable)
# =============================================================================
android/local.properties
android/.gradle/
android/.idea/
android/.kotlin/
android/build/
android/app/build/
android/captures/
android/.cxx/
android/app/release/
android/app/debug/
*.iml
*.apk
*.aab
*.ap_
*.dex
.externalNativeBuild/
