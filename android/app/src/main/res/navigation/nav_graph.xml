<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.jornadasaludable.app.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.jornadasaludable.app.ui.dashboard.DashboardFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/fichajeFragment"
        android:name="com.jornadasaludable.app.ui.fichaje.FichajeFragment"
        android:label="Fichaje"
        tools:layout="@layout/fragment_fichaje" />

    <fragment
        android:id="@+id/alertasFragment"
        android:name="com.jornadasaludable.app.ui.alertas.AlertasFragment"
        android:label="Alertas"
        tools:layout="@layout/fragment_alertas" />

    <fragment
        android:id="@+id/estadisticasFragment"
        android:name="com.jornadasaludable.app.ui.estadisticas.EstadisticasFragment"
        android:label="Estadísticas"
        tools:layout="@layout/fragment_estadisticas" />

    <fragment
        android:id="@+id/derechosFragment"
        android:name="com.jornadasaludable.app.ui.derechos.DerechosFragment"
        android:label="Mis Derechos"
        tools:layout="@layout/fragment_derechos">

        <action
            android:id="@+id/action_derechos_to_detail"
            app:destination="@id/derechoDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/derechoDetailFragment"
        android:name="com.jornadasaludable.app.ui.derechos.DerechoDetailFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_derecho_detail">
        <argument
            android:name="codigo"
            app:argType="string" />
    </fragment>

</navigation>
